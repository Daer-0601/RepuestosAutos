# MySQL (solo servidor; no exponer al cliente)
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# TLS (Aiven y otros suelen exigirlo). Ruta al CA PEM, relativa al cwd o absoluta.
# DATABASE_SSL=true
# DATABASE_SSL_CA=ca.pem
# Solo si el certificado no encaja con la CA del sistema:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Opcional: límite de conexiones del pool (default 10)
# DATABASE_POOL_LIMIT=10

# Opcional: timeout de conexión TCP en ms (default 10000 en app; el script ping usa 20000)
# DATABASE_CONNECT_TIMEOUT_MS=20000

# Sesión (JWT en cookie httpOnly). Generá un string largo aleatorio (p. ej. openssl rand -hex 32).
AUTH_SECRET=

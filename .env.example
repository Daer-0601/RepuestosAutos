# MySQL (solo servidor; no exponer al cliente)
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# TLS (Aiven y otros suelen exigirlo).
# DATABASE_SSL=true
# En Vercel: pegá el PEM completo (con -----BEGIN/END-----) en una sola variable multilínea:
# DATABASE_SSL_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# En local: archivo PEM en el repo o ruta absoluta:
# DATABASE_SSL_CA=ca.pem
# Solo si el certificado no encaja con la CA del sistema:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Opcional: límite de conexiones del pool (default 10)
# DATABASE_POOL_LIMIT=10

# Opcional: timeout de conexión TCP en ms (default 10000 en app; el script ping usa 20000)
# DATABASE_CONNECT_TIMEOUT_MS=20000

# Sesión (JWT en cookie httpOnly). Generá un string largo aleatorio (p. ej. openssl rand -hex 32).
AUTH_SECRET=

# Imágenes de productos en Vercel: creá un Blob store en el dashboard; Vercel crea esta variable.
# Local: `vercel env pull` o copiá el token del store a .env.local
# BLOB_READ_WRITE_TOKEN=
